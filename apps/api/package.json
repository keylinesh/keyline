{
  "name": "@keyline/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./app": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(lint: configure eslint)\"",
    "test": "KEYLINE_LOG_SILENT=1 node --import tsx --test $(find src -name '*.test.ts')",
    "dev": "node --import tsx src/index.ts",
    "db:migrate": "node --import tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@keyline/crypto": "workspace:*",
    "@keyline/shared": "workspace:*",
    "hono": "^4.6.0",
    "pg": "^8.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0"
  }
}
