{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[[...route]]"
    },
    {
      "source": "/install",
      "destination": "/install.sh"
    },
    {
      "source": "/guides/docker-env-secrets",
      "destination": "/guide-docker-env.html"
    },
    {
      "source": "/guides/dotenv-in-ci",
      "destination": "/guide-dotenv-ci.html"
    },
    {
      "source": "/guides/nextjs-environment-variables",
      "destination": "/guide-nextjs-env.html"
    },
    {
      "source": "/blog/audit-log-cant-lie",
      "destination": "/blog-audit-log-cant-lie.html"
    },
    {
      "source": "/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/guides/share-env-files-with-team",
      "destination": "/share-env-files-with-team.html"
    },
    {
      "source": "/vs/dotenv-vault",
      "destination": "/vs-dotenv-vault.html"
    },
    {
      "source": "/vs/vault",
      "destination": "/vs-vault.html"
    },
    {
      "source": "/vs/infisical",
      "destination": "/vs-infisical.html"
    },
    {
      "source": "/open",
      "destination": "/open.html"
    },
    {
      "source": "/vs/sharing-env-in-slack",
      "destination": "/vs-sharing-env-in-slack.html"
    },
    {
      "source": "/vs/doppler",
      "destination": "/vs-doppler.html"
    },
    {
      "source": "/security",
      "destination": "/security.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/dpa",
      "destination": "/dpa.html"
    },
    {
      "source": "/refunds",
      "destination": "/refunds.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/app/index.html"
    }
  ],
  "headers": [
    {
      "source": "/install",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/v1/billing/reconcile",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/v1/audit/anchor",
      "schedule": "30 6 * * *"
    }
  ]
}
