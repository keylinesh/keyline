{
  "name": "keyline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Zero-knowledge secrets manager for small dev teams",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vercel/node": "^5.8.24",
    "autocannon": "^8",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@keyline/api": "workspace:*",
    "@vercel/postgres": "^0.10.0",
    "hono": "^4.6.0"
  }
}
