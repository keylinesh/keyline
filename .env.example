# Keyline environment variables (example — no real secrets here).
#
# Local dev: copy to `.env` and fill in. `.env` is gitignored.
# Staging / production: set these in the platform's secrets manager
#   (Vercel Environment Variables + GitLab CI masked variables) — NEVER in the repo.

# Which deployment this is: development | staging | production.
# Drives HTTPS enforcement and the /health environment field.
APP_ENV=development

# Postgres (Neon). Pooled URL for the app; unpooled for migrations.
# Get these from the Neon console → Connection Details.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL_UNPOOLED=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# API server port (local only; Vercel provides its own).
PORT=3000
